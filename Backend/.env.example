# ============================================================
# The Wealth Method Backend — Environment Variables
# ============================================================

# Server
PORT=8080
NODE_ENV=development
JWT_SECRET_KEY=your-very-secure-jwt-secret-key-change-me
cryptoKey=your-very-secure-crypto-key

# MongoDB (CloudPlay format)
mongodbName=wealthmethod
mongouserName=
mongopass=

# Redis (CloudPlay format)
redis_server=127.0.0.1
redis_port=6379
redis_username=default
redis_pass=

# Admin seed credentials
ADMIN_EMAIL=admin@wealthmethod.com
ADMIN_PASSWORD=Admin@123456

# Basic Auth (CloudPlay format)
basicauthusername=wealthapi
basicauthpass=wealth_secret_pass

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGINS=http://localhost:3000

# Email (CloudPlay format)
emailUser=your@gmail.com
emailPass=your_app_password
emailFrom=noreply@wealthmethod.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=
